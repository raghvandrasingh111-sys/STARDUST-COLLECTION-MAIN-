# MongoDB Configuration
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.mongodb.net/stardust?retryWrites=true&w=majority

# Supabase Authentication & Storage Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Admin Service Role Key (Server-Side Only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Admin Authentication
# Comma-separated list of email addresses allowed to access the admin portal
ADMIN_EMAILS=admin@stardustcollections.com,owner@stardustcollections.com
NEXT_PUBLIC_ADMIN_EMAILS=admin@stardustcollections.com,owner@stardustcollections.com
